{
  "name": "pantry-iq-landing",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prettify": "prettier --write .",
    "lint": "eslint",
    "fixLint": "prettier --write . && eslint --fix .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest --run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "ciTests": "prettier --check . && npm run lint && tsc --noEmit && npm run build && npm run test:unit",
    "generate:test-csv": "ts-node scripts/generate-test-csv.ts",
    "generate:test-csv-faker": "ts-node scripts/generate-test-csv-faker.ts",
    "docker:build": "docker build -t pantryiq:latest ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.52",
    "@radix-ui/react-label": "^2.1.8",
    "ai": "^6.0.158",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.564.0",
    "next": "16.2.3",
    "postgres": "^3.4.9",
    "posthog-js": "^1.359.1",
    "posthog-node": "^5.28.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
