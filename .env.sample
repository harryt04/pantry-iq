# ============================================================================
# PantryIQ MVP Environment Variables
# ============================================================================
# Copy this file to .env and fill in the required values.
# Most API keys below can be stubbed with placeholder values for initial dev.
# ============================================================================

# Database (PostgreSQL)
# Local dev: postgres://postgres:password@localhost:5432/pantryiq
# Production: Set via Coolify secrets
DATABASE_URL=postgres://postgres:password@localhost:5432/pantryiq

# Zero Sync Cache Server (Rocicorp)
# Local dev: use same Postgres as above
# Production: Set via Coolify secrets
ZERO_UPSTREAM_DB=postgres://postgres:password@localhost:5432/pantryiq
ZERO_PORT=8001

# Better Auth (Authentication)
# Generate secret: openssl rand -base64 32
# Must be at least 32 characters
BETTER_AUTH_SECRET=your-generated-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Square POS Integration (Optional - stub OK for dev)
# Sign up: https://developer.squareup.com
# Get keys from Square Developer Dashboard
SQUARE_APP_ID=your-square-app-id
SQUARE_APP_SECRET=your-square-app-secret
SQUARE_ENVIRONMENT=sandbox

# LLM Providers (At least one required for chatbot)
# Optional - stub values OK for initial dev, replace with real keys later
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google AI: https://ai.google.dev
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Weather Data (Optional - stub OK for dev)
# OpenWeatherMap: https://openweathermap.org/api (free tier available)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Places & Donation Intelligence (Optional - stub OK for dev)
# Google Places: https://console.cloud.google.com (enable Places API)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# PostHog Analytics (Existing - do not change)
# Already configured in repository
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

