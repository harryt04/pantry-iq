# ============================================================================
# PantryIQ MVP Environment Variables
# ============================================================================
# Copy this file to .env and fill in the required values.
# Most API keys below can be stubbed with placeholder values for initial dev.
# ============================================================================

# Database (PostgreSQL)
# Local dev: postgres://postgres:password@localhost:5432/pantryiq
# Production: Set via Coolify secrets
#
# Multi-environment Setup (PostgreSQL Schemas):
# One PostgreSQL database can contain multiple schemas for different environments.
# By default, all environments use the 'public' schema. For isolated testing:
#
# - Local dev: Uses 'public' schema (default)
# - CI/GitHub Actions: Uses 'ci_test' schema (set DATABASE_SCHEMA=ci_test)
# - Production: Uses 'public' schema
#
# See DATABASE_SCHEMA below to switch schemas.
DATABASE_URL=

# PostgreSQL Schema Selection
# Default: 'public' (used for local dev and production)
# For CI testing: Set to 'ci_test' to use an isolated test schema
# Each schema has its own set of tables, allowing multiple environments
# in a single PostgreSQL database.
DATABASE_SCHEMA=public

# Zero Sync Cache Server (Rocicorp)
# Local dev: use same Postgres as above
# Production: Set via Coolify secrets
ZERO_UPSTREAM_DB=
ZERO_PORT=
NEXT_PUBLIC_ZERO_URL=http://localhost:8001

# Better Auth (Authentication)
# Generate secret: openssl rand -base64 32
# Must be at least 32 characters
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
NEXT_PUBLIC_BETTER_AUTH_URL=

# Square POS Integration (Optional - stub OK for dev)
# Sign up: https://developer.squareup.com
# Get keys from Square Developer Dashboard
# OAuth redirect URL: http://localhost:3000/api/square/callback
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENVIRONMENT=sandbox

# Encryption key for storing tokens (optional, uses BETTER_AUTH_SECRET if not set)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# LLM Providers (At least one required for chatbot)
# Optional - stub values OK for initial dev, replace with real keys later
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google AI: https://ai.google.dev
GOOGLE_GENERATIVE_AI_API_KEY=

# Weather Data (Optional - stub OK for dev)
# OpenWeatherMap: https://openweathermap.org/api (free tier available)
OPENWEATHERMAP_API_KEY=

# Places & Donation Intelligence (Optional - stub OK for dev)
# Google Places: https://console.cloud.google.com (enable Places API)
GOOGLE_PLACES_API_KEY=

# PostHog Analytics (Existing - do not change)
# Already configured in repository
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

